{
  "name": "@newfold/ui-component-library",
  "version": "2.1.1",
  "description": "A UI component library by Newfold Digital",
  "main": "build/index.js",
  "style": "build/css/style.css",
  "author": {
    "name": "Newfold Labs",
    "url": "https://github.com/newfold-labs"
  },
  "homepage": "https://github.com/newfold-labs/npm-ui-component-library#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/newfold-labs/npm-ui-component-library.git"
  },
  "license": "GPL-3.0",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "clean:build": "rm -rf build",
    "build": "npm run clean:build && npm run build:js && npm run build:css && npm run copy:package-files",
    "build:js": "babel src --out-dir build --ignore \"src/**/*.stories.js\",\"src/**/stories.js\"",
    "build:css": "node ./scripts/build-css.js",
    "copy:package-files": "node ./scripts/prepare-build-package.js",
    "watch": "npm run watch:js & npm run watch:css",
    "watch:js": "npm run build:js -- --watch",
    "watch:css": "node ./scripts/watch-css.js",
    "test": "npm test:storyshots",
    "prebuild:cy:css": "npm run build",
    "build:cy:css": "cross-env TAILWIND_CONFIG=cypress/tailwind.config.js postcss cypress/style.css -o cypress/styles/style.css",
    "precy:open": "npm run build:cy:css",
    "cy:open": "cypress open --component",
    "precy:run": "npm run build:cy:css",
    "cy:run": "cypress run --component",
    "lint": "eslint src --max-warnings=0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/eslint-plugin": "^7.19.1",
    "@babel/parser": "^7.20.5",
    "@babel/plugin-transform-optional-chaining": "^7.24.8",
    "@babel/plugin-transform-runtime": "^7.22.9",
    "@babel/preset-react": "^7.22.0",
    "@mdx-js/react": "^2.1.5",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@wordpress/babel-preset-default": "^8.42.0",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^9.1.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "cypress": "^15.4.0",
    "eslint": "^8.57.1",
    "eslint-config-yoast": "^5.1.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-react": "^7.31.11",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.18"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^1.0.6",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "classnames": "^2.3.2",
    "lodash": "^4.17.21",
    "postcss-import": "^16.1.1",
    "prop-types": "^15.8.1",
    "react-animate-height": "^3.1.0",
    "react-error-boundary": "^3.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
